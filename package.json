{
  "name": "dmmc-app",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build:bookmarklets": "node scripts/build-bookmarklets.mjs",
    "build:scripts": "webpack --config webpack.scripts.config.cjs",
    "watch:scripts": "webpack --config webpack.scripts.config.cjs --env development --watch",
    "build": "npm run build:bookmarklets && next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "commitlint:edit": "commitlint --edit",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.13",
    "better-auth": "1.4.9",
    "convex": "^1.32.0",
    "dexie": "^4.3.0",
    "dom-to-image": "^2.6.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/dom-to-image": "^2.6.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4",
    "ts-loader": "^9.5.2",
    "typescript": "^5",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}